{
  "name": "@digdir/einnsyn-sdk",
  "version": "1.2.0",
  "description": "TypeScript client library for the eInnsyn API",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "25.4.0",
    "@vitest/coverage-v8": "^4.1.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "tsup",
    "format": "biome format --write .",
    "test": "npm run test:typecheck && npm run test:run",
    "test:run": "vitest run",
    "test:typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test:coverage": "npm run test:typecheck && vitest run --coverage",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "homepage": "https://github.com/felleslosninger/einnsyn-sdk-typescript",
  "repository": {
    "type": "git",
    "url": "git://github.com/felleslosninger/einnsyn-sdk-typescript.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "BSD-3-Clause"
}
